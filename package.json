{
  "name": "playlist-data-engine",
  "description": "TypeScript library for parsing music playlists, analyzing audio signatures, and generating D&D 5e-inspired characters with progression, combat, and sensor integration",
  "version": "1.1.0",
  "type": "module",
  "main": "./dist/playlist-data-engine.js",
  "module": "./dist/playlist-data-engine.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/playlist-data-engine.mjs",
      "require": "./dist/playlist-data-engine.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "d&d",
    "character-generation",
    "audio-analysis",
    "progression-system",
    "rpg"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.declarations.json",
    "build:strict": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@types/uuid": "^10.0.0",
    "essentia.js": "^0.1.3",
    "murmurhash-v3": "^1.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0",
    "@ryuziii/discord-rpc": "^1.0.1-rc.1"
  },
  "peerDependenciesMeta": {
    "@ryuziii/discord-rpc": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "canvas": "^3.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.14",
    "web-audio-api": "^0.2.2"
  }
}
