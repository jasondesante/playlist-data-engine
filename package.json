{
  "name": "playlist-data-engine",
  "description": "TypeScript library for parsing music playlists, analyzing audio signatures, and generating D&D 5e-inspired characters with progression, combat, and sensor integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasondesante/playlist-data-engine.git"
  },
  "version": "1.5.0",
  "type": "module",
  "main": "./dist/playlist-data-engine.js",
  "module": "./dist/playlist-data-engine.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/playlist-data-engine.mjs",
      "require": "./dist/playlist-data-engine.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "arweave",
    "ethereum",
    "music-nfts",
    "web3-music",
    "decentralized-music",
    "serverless-playlists",
    "permaweb",
    "ario-wayfinder",
    "decentralized-playlists",
    "gamified-music",
    "music-gamification",
    "rhythm-game-engine",
    "rpg-character-generator",
    "dnd-5e",
    "xp-system",
    "beat-detection",
    "audio-analysis",
    "music-classification",
    "pitch-detection",
    "combat-simulator",
    "sensor-integration",
    "rhythm-game"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.declarations.json",
    "build:strict": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ar.io/sdk": "^4.0.3",
    "@ar.io/wayfinder-core": "^2.0.1",
    "@tensorflow/tfjs": "^4.22.0",
    "essentia.js": "^0.1.3",
    "localforage": "^1.10.0",
    "murmurhash-v3": "^1.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "canvas": "^3.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.0.14",
    "web-audio-api": "^0.2.2"
  }
}
