{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "noFallthroughCasesInSwitch": false,
    "noUncheckedSideEffectImports": false,
    "downlevelIteration": true
  },
  "include": ["src"]
}
