# Discord RPC Configuration
# To enable Discord Rich Presence integration:
# 1. Create a Discord application at https://discord.com/developers/applications
# 2. Copy the Client ID from the "General Information" page
# 3. Set the DISCORD_CLIENT_ID below

DISCORD_CLIENT_ID=your_discord_client_id_here

# Note: Discord RPC requires Discord to be running on the user's machine.
# The library will gracefully degrade if Discord is not available.
